# Repo-wide ignores. Note: client/, server/, and infra/terraform/ have their own
# .gitignore for app-specific build output — this covers OS/editor cruft and acts as a
# belt-and-suspenders net for env files and dependencies at any level.

# macOS / Windows / editor cruft
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
*~
*.swp
*.swo
.idea/

# Secrets / env (never commit; .env.example is kept)
.env
.env.*
!.env.example

# Testing Portal local config (see server/testing-portal.example.json)
testing-portal.json
testing-portal.*.json
!testing-portal.example.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# NOTE: dependency/build output (node_modules, dist, .next) is intentionally left to the
# per-app .gitignore files (client/, server/). A repo-wide `dist/` here would also ignore
# the deliberately-committed vendored SDK at server/vendor/newton-auth/dist.
