{
  "_comment": "ECS task EXECUTION role — used by the ECS agent to pull images, fetch secrets for injection, and write logs. Scoped to THIS app's ECR repos, secrets prefix, KMS CMK, and log groups only. No wildcards across the account. See docs/infra-ecs.md.",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "EcrAuthToken",
      "Effect": "Allow",
      "Action": ["ecr:GetAuthorizationToken"],
      "Resource": "*",
      "_note": "GetAuthorizationToken does not support resource-level scoping; the pull below is scoped."
    },
    {
      "Sid": "PullOwnImagesOnly",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:GetDownloadUrlForLayer",
        "ecr:BatchGetImage"
      ],
      "Resource": [
        "arn:aws:ecr:<REGION>:<ACCOUNT_ID>:repository/forge-server",
        "arn:aws:ecr:<REGION>:<ACCOUNT_ID>:repository/forge-client"
      ]
    },
    {
      "Sid": "InjectOwnSecretsOnly",
      "Effect": "Allow",
      "Action": ["secretsmanager:GetSecretValue"],
      "Resource": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/*"
    },
    {
      "Sid": "DecryptOwnCmkOnly",
      "Effect": "Allow",
      "Action": ["kms:Decrypt"],
      "Resource": "arn:aws:kms:<REGION>:<ACCOUNT_ID>:key/<FORGE_CMK_ID>"
    },
    {
      "Sid": "CreateOwnLogGroups",
      "Effect": "Allow",
      "Action": ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"],
      "Resource": "arn:aws:logs:<REGION>:<ACCOUNT_ID>:log-group:/ecs/forge/*"
    }
  ]
}
