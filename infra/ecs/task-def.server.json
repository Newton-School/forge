{
  "_comment": "ECS Fargate task definition — SERVER (Express). Placeholders: <ACCOUNT_ID>, <REGION>, <ENV>. Secrets are pulled from Secrets Manager (namespaced /forge/<ENV>/*), never baked into the image. See docs/infra-ecs.md.",
  "family": "forge-server-<ENV>",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": { "cpuArchitecture": "X86_64", "operatingSystemFamily": "LINUX" },
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/forge-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/forge-server-task-role",
  "tags": [
    { "key": "app", "value": "forge" },
    { "key": "env", "value": "<ENV>" }
  ],
  "containerDefinitions": [
    {
      "name": "server",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/forge-server:<IMAGE_TAG>",
      "essential": true,
      "portMappings": [{ "containerPort": 8000, "protocol": "tcp" }],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "8000" },
        { "name": "APP_BASE_URL", "value": "<APP_ORIGIN>" },
        { "name": "GOOGLE_OAUTH_REDIRECT_URI", "value": "<APP_ORIGIN>/api/auth/google/callback" },
        { "name": "GITHUB_OAUTH_REDIRECT_URI", "value": "<APP_ORIGIN>/api/integrations/github/oauth/callback" },
        { "name": "ALLOWED_HOSTED_DOMAIN", "value": "rishihood.edu.in" },
        { "name": "SMTP_FAMILY", "value": "4" },
        { "name": "GROQ_MODEL", "value": "llama-3.1-8b-instant" }
      ],
      "secrets": [
        { "name": "DATABASE_URL",               "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/DATABASE_URL" },
        { "name": "DIRECT_URL",                  "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/DIRECT_URL" },
        { "name": "REDIS_URL",                   "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/REDIS_URL" },
        { "name": "SESSION_SECRET",              "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/SESSION_SECRET" },
        { "name": "GOOGLE_OAUTH_CLIENT_ID",      "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/GOOGLE_OAUTH_CLIENT_ID" },
        { "name": "GOOGLE_OAUTH_CLIENT_SECRET",  "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/GOOGLE_OAUTH_CLIENT_SECRET" },
        { "name": "SMTP_HOST",                   "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/SMTP_HOST" },
        { "name": "SMTP_PORT",                   "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/SMTP_PORT" },
        { "name": "SMTP_USER",                   "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/SMTP_USER" },
        { "name": "SMTP_PASS",                   "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/SMTP_PASS" },
        { "name": "SMTP_FROM",                   "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/SMTP_FROM" },
        { "name": "GITHUB_APP_PRIVATE_KEY",      "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/GITHUB_APP_PRIVATE_KEY" },
        { "name": "GITHUB_WEBHOOK_SECRET",       "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/GITHUB_WEBHOOK_SECRET" },
        { "name": "DISCORD_BOT_TOKEN",           "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/DISCORD_BOT_TOKEN" },
        { "name": "GROQ_API_KEY",                "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:/forge/<ENV>/GROQ_API_KEY" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/forge/<ENV>/server",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "server"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://127.0.0.1:8000/api/health || exit 1"],
        "interval": 30, "timeout": 5, "retries": 3, "startPeriod": 15
      },
      "readonlyRootFilesystem": false,
      "linuxParameters": { "initProcessEnabled": true }
    }
  ]
}
