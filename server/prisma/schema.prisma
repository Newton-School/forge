// Forge — Prisma schema (server-owned). Postgres (RDS in prod).
// Runtime uses pooled DATABASE_URL; migrations use the direct DIRECT_URL.

generator client {
  provider = "prisma-client-js"
}

// Prisma 7: connection URLs live in prisma.config.ts (Migrate/CLI) and the
// driver adapter in src/lib/db.ts (runtime). The datasource only names the provider.
datasource db {
  provider = "postgresql"
}

// ───────────────────────── Enums ─────────────────────────
// The Student Mentor leads their team — there is no separate Team Lead role.
enum RoleKey {
  ADMIN
  LCC
  TEACHER
  MENTOR
  MENTEE
}

enum ScopeType {
  GLOBAL
  DOMAIN
  TEAM
  SELF
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum TeamAlias {
  POD
  GROUP
  TEAM
  SQUAD
}

enum ProjectType {
  GROUP
  INDIVIDUAL
}

enum ProposalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REVISE_RESUBMIT
  REJECTED
}

enum WorkStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  RELEASED
  BLOCKED
}

enum ReviewLevel {
  L1
  L2
  L3
  L4
}

// Tracking-sheet vocabulary (verbatim intent)
enum MenteeStatusL2 {
  DOING_WELL // 🟢
  NEEDS_CONSISTENCY // 🟡
  NO_UPDATES_4PLUS // 🔴
}

enum MentorStatusL3 {
  ON_TRACK
  AT_RISK
  NEEDS_DISCUSSION
}

enum TeacherDecisionL4 {
  CONTINUE
  MONITOR
  SCHEDULE_DISCUSSION
}

enum AutoFlag {
  NONE
  CONSISTENCY_GAP // <3 updates in a week
  REPEATED_BLOCKER // same blocker 3+ updates
  NO_UPDATES // 🔴 inactivity threshold
}

enum ConcernCategory {
  MENTOR
  MENTEE
  TEACHER
  TEAM_MEMBER
  DOMAIN_ISSUE
  TECHNICAL_ISSUE
  PROCESS_ISSUE
  OTHER
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ConcernStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  ESCALATED
  RESOLVED
  CLOSED
  REOPENED
}

enum DeliverableReview {
  PENDING
  APPROVED
  REJECTED
}

enum EmailStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

enum IntegrationProvider {
  GITHUB
  DISCORD
  GOOGLE_CALENDAR
}

enum ActivityType {
  COMMIT
  PR
  ISSUE
  REVIEW
  MESSAGE
  JOIN
  REACTION
  ANNOUNCEMENT
}

enum CalendarEventType {
  MENTOR_MEETING
  REVIEW
  DEADLINE
  MILESTONE
  EVENT
}

// Single-row snapshot of NON-SENSITIVE aggregate metrics shown on the PUBLIC
// landing page. Recomputed by a secret-gated job; the public read endpoint serves
// only this row (no live-table access, no PII, no user input) so it can never be a
// way into the database. Nullable columns => "Coming Soon" until data exists.
model PlatformStat {
  id                   String   @id @default("current") // singleton
  contributionsTracked Int? // commits + PRs + issues + reviews synced
  prsReviewedPct       Int? // % of PRs that received a review
  milestonesOnTrackPct Int? // % of milestones progressing / done (not blocked)
  consistencyLiftPct   Int? // change in update consistency since drive start
  computedAt           DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ─────────────────── Identity & Access (M1) ───────────────────
model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  fullName           String
  status             UserStatus @default(INVITED)
  googleSub          String?    @unique // Google OIDC subject — set on first login (legacy Google auth)
  newtonUid          String?    @unique // Newton School opaque user id — stable identity key for Newton login
  avatarUrl          String?
  passwordHash       String? // unused under Google-only auth; retained for schema stability
  mustChangePassword Boolean    @default(false)
  tokenVersion       Int        @default(0)
  mfaSecret          String?
  failedLoginCount   Int        @default(0)
  lockedUntil        DateTime?
  lastLoginAt        DateTime?
  discordUsername    String? // Discord username — display only; can be changed by the user
  discordUserId      String? @unique // permanent Discord id (snowflake, as string) — match bot/gateway activity to this, NOT the username
  githubUsername     String? // GitHub login — display only; can be renamed by the user
  githubUserId       String? @unique // permanent numeric GitHub id (as string) — match activity/webhooks to this, NOT the login
  githubConnectedAt  DateTime? // when the user authorized the GitHub App (per-user identity link)
  createdById        String?
  createdBy          User?      @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers       User[]     @relation("UserCreatedBy")

  roles            UserRole[]
  teamMemberships  TeamMember[]
  mentorTeams      Team[]          @relation("TeamMentor")
  // A teacher can be assigned to MANY domains (and a domain can have co-teachers):
  taughtDomains    Domain[]        @relation("DomainTeachers")
  menteeUpdates    MenteeUpdate[]
  invitations      Invitation[]
  passwordResets   PasswordReset[]
  concernsRaised   Concern[]       @relation("ConcernRaisedBy")
  concernsAssigned Concern[]       @relation("ConcernAssignee")
  demerits         Demerit[]       @relation("DemeritUser")
  auditLogs        AuditLog[]
  notifications    Notification[]
  ownedRepos       Repository[]    @relation("RepoOwner")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
}

model UserRole {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      RoleKey
  scopeType ScopeType @default(SELF)
  scopeId   String? // Domain or Team id when scoped
  createdAt DateTime  @default(now())

  @@unique([userId, role, scopeType, scopeId])
  @@index([role, scopeType, scopeId])
}

enum InvitationStatus {
  PENDING
  SENT
  OPENED
  COMPLETED
  EXPIRED
}

model Invitation {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      String // denormalized recipient — audit + resend without a user join
  token      String           @unique
  status     InvitationStatus @default(PENDING)
  expiresAt  DateTime
  sentAt     DateTime? // set when the onboarding email is dispatched
  openedAt   DateTime? // set by the tracking pixel
  acceptedAt DateTime? // set on first successful Google sign-in
  createdAt  DateTime         @default(now())

  @@index([userId])
  @@index([status])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// ─────────────────── Org Structure (M2) ───────────────────
model Drive {
  id       String   @id @default(cuid())
  name     String
  year     Int
  active   Boolean  @default(true)
  domains  Domain[]
  phases   Phase[]
  rubrics  Rubric[]
  escalationRules EscalationRule[]
  reviewCycles ReviewCycle[]
  createdAt DateTime @default(now())
}

// How a domain structures its GitHub repositories — drives the team-first, domain-adaptive
// dashboards. ORG = AI (org + shared team repos); SHARED = DVA/SDSE (one shared team repo);
// PER_STUDENT = ML (one independent repo per student within a team).
enum DomainRepoModel {
  ORG
  SHARED
  PER_STUDENT
}

model Domain {
  id        String  @id @default(cuid())
  driveId   String
  drive     Drive   @relation(fields: [driveId], references: [id])
  name      String
  key       String
  active    Boolean @default(true)
  githubRepoModel DomainRepoModel @default(SHARED)
  governanceProfile Json? // team model, branch policy, default rubric, deliverable types
  // Many-to-many: a domain can have one or more teachers; a teacher can span domains.
  teachers  User[]  @relation("DomainTeachers")
  teams     Team[]

  @@index([driveId])
}

model Team {
  id              String     @id @default(cuid())
  domainId        String
  domain          Domain     @relation(fields: [domainId], references: [id])
  name            String
  alias           TeamAlias  @default(TEAM)
  // The Student Mentor is the team lead (no separate Team Lead role).
  mentorId        String?
  mentor          User?      @relation("TeamMentor", fields: [mentorId], references: [id])
  githubRepoUrl   String?
  githubRepoName  String? // display name, e.g. "newton-school-ai/engageiq-ai"
  discordChannelId String?
  members         TeamMember[]
  projects        Project[]
  // Shared model (DVA/SDSE) → one repo; per-student model (ML) → one repo per student.
  repositories    Repository[]

  @@index([domainId])
}

// ── Repository mode (ML/DVA/SDSE) — one connected public repo per team ───────────────
enum RepoVisibility {
  PUBLIC
  PRIVATE
}

enum RepoPermission {
  ADMIN
  WRITE
  READ
}

enum RepoCollabRole {
  OWNER
  MAINTAINER
  COLLABORATOR
}

model Repository {
  id            String             @id @default(cuid())
  teamId        String // a team may own many repos (per-student model) or one (shared)
  team          Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  // The student who owns this repo in the per-student (ML) model; null for a shared team repo.
  ownerUserId   String?
  ownerUser     User?              @relation("RepoOwner", fields: [ownerUserId], references: [id])
  ownerRole     RepoCollabRole     @default(OWNER) // who owns it: team lead, mentor, or student
  owner         String // GitHub owner login (student, team lead, or mentor)
  name          String
  fullName      String             @unique
  visibility    RepoVisibility     @default(PUBLIC)
  description   String?
  defaultBranch String             @default("main")
  hasIssues     Boolean            @default(false)
  topics        String[]
  lastSyncedAt  DateTime? // last successful GitHub → DB sync
  collaborators RepoCollaborator[]
  branches      RepoBranch[]
  releases      RepoRelease[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([teamId])
}

// Captured at connect time using the OWNER's token (listing collaborators needs write
// access, which the read-only machine token doesn't have) — closes the collaborators gap.
model RepoCollaborator {
  id           String         @id @default(cuid())
  repositoryId String
  repository   Repository     @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  login        String
  permission   RepoPermission @default(READ)
  repoRole     RepoCollabRole @default(COLLABORATOR)

  @@unique([repositoryId, login])
}

model RepoBranch {
  id           String     @id @default(cuid())
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  name         String
  protected    Boolean    @default(false)
  sha          String

  @@unique([repositoryId, name])
}

model RepoRelease {
  id           String     @id @default(cuid())
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  tag          String
  name         String
  publishedAt  DateTime
  author       String?
  notes        String?

  @@unique([repositoryId, tag])
}

model Squad {
  id      String       @id @default(cuid())
  name    String // Alpha / Beta / Gamma
  members TeamMember[]
}

model TeamMember {
  id          String  @id @default(cuid())
  teamId      String
  team        Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId      String
  user        User    @relation(fields: [userId], references: [id])
  memberRole  String // Mentee | Contributor | Maintainer | Junior | Engineer ...
  squadId     String?
  squad       Squad?  @relation(fields: [squadId], references: [id])
  githubPermission String?
  // PER_STUDENT domains (e.g. ML): each member binds their OWN repo (the team is a grouping layer).
  // SHARED/ORG domains use Team.githubRepoUrl / the org instead, so these stay null there.
  githubRepoUrl  String?
  githubRepoName String? // display name, e.g. "khushi-ml/forecasting"

  @@unique([teamId, userId])
  @@index([userId])
}

// ─────────────────── Drive Configuration (M3) ───────────────────
model Phase {
  id            String      @id @default(cuid())
  driveId       String
  drive         Drive       @relation(fields: [driveId], references: [id])
  name          String
  sequence      Int
  startsAt      DateTime? // exact start (calendar)
  endsAt        DateTime? // exact end (calendar)
  durationLabel String? // optional display label, derivable from startsAt/endsAt
  theme         String?
  domainId      String? // scope: null = all domains, else this domain only
  gates         Gate[]
  milestones    Milestone[]

  @@index([driveId])
  @@index([domainId])
}

model Gate {
  id                String    @id @default(cuid())
  phaseId           String
  phase             Phase     @relation(fields: [phaseId], references: [id])
  name              String
  scheduledAt       DateTime? // exact gate date/time (calendar)
  verdictOptions    Json // ["Approved","Revise & Resubmit","Rejected"]
  blocksProgression Boolean   @default(true)
  domainId          String? // scope: null = all domains, else this domain only
}

// Cadence stored as a NUMBER + UNIT the scheduler reads — not the text "every 2 days".
// e.g. intervalValue=2, intervalUnit=DAY  →  "every 2 days".
enum CadenceUnit {
  DAY
  WEEK
  MONTH
}

model ReviewCycle {
  id            String      @id @default(cuid())
  driveId       String
  drive         Drive       @relation(fields: [driveId], references: [id])
  level         ReviewLevel
  ownerRole     RoleKey
  intervalValue Int // e.g. 2  ← a real number
  intervalUnit  CadenceUnit // DAY → "every 2 days"
  anchorDay     String? // optional weekday for weekly cadences, e.g. "Saturday"
  domainId      String? // scope: null = all domains, else this domain only
  fieldSchema   Json
  statusEnum    Json

  @@index([domainId])
}

model EscalationRule {
  id             String  @id @default(cuid())
  driveId        String
  drive          Drive   @relation(fields: [driveId], references: [id])
  name           String
  condition      Json
  thresholdValue Int
  thresholdUnit  String // days | updates | hours
  action         String // FLAG | NOTIFY | ESCALATE
  targetRole     RoleKey?
  severity       Severity?
  domainId       String? // scope: null = all domains, else this domain only

  @@index([domainId])
}

model Rubric {
  id         String            @id @default(cuid())
  driveId    String
  drive      Drive             @relation(fields: [driveId], references: [id])
  domainId   String?
  name       String
  kind       String // GATE | TOP_TEAM | MENTOR
  dimensions RubricDimension[]
}

model RubricDimension {
  id         String @id @default(cuid())
  rubricId   String
  rubric     Rubric @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  name       String
  weight     Float
  measuredBy String
}

model DeliverableType {
  id       String        @id @default(cuid())
  domainId String?
  name     String
  deliverables Deliverable[]
}

// ─────────────────── Projects & Work (M4) ───────────────────
model Project {
  id               String         @id @default(cuid())
  teamId           String
  team             Team           @relation(fields: [teamId], references: [id])
  type             ProjectType
  ownerId          String?
  name             String
  problemStatement String?
  status           WorkStatus     @default(TODO)
  proposalStatus   ProposalStatus @default(DRAFT)
  milestones       Milestone[]
  tasks            Task[]
  deliverables     Deliverable[]

  @@index([teamId])
}

model Milestone {
  id                 String     @id @default(cuid())
  projectId          String?
  project            Project?   @relation(fields: [projectId], references: [id])
  phaseId            String?
  phase              Phase?     @relation(fields: [phaseId], references: [id])
  name               String
  sequence           Int
  keyOutput          String?
  acceptanceCriteria Json?
  defenseQuestions   Json?
  dueAt              DateTime?
  status             WorkStatus @default(TODO)
  completionPct      Int        @default(0)
  signedOffById      String?
  signedOffAt        DateTime?
  tasks              Task[]
  deliverables       Deliverable[]

  @@index([projectId])
}

model Task {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id])
  milestoneId String?
  milestone   Milestone? @relation(fields: [milestoneId], references: [id])
  title       String
  description String?
  assigneeId  String?
  assignedById String?
  assignedAt  DateTime   @default(now())
  dueAt       DateTime?
  status      WorkStatus @default(TODO)
  progressPct Int        @default(0)
  nextAction  String?

  @@index([assigneeId])
}

model Deliverable {
  id            String            @id @default(cuid())
  name          String? // human title shown in the UI (e.g. "Sprint 2 Demo")
  projectId     String
  project       Project           @relation(fields: [projectId], references: [id])
  milestoneId   String?
  milestone     Milestone?        @relation(fields: [milestoneId], references: [id])
  typeId        String?
  type          DeliverableType?  @relation(fields: [typeId], references: [id])
  submittedById String?
  submittedAt   DateTime?
  artifactUrl   String?
  reviewStatus  DeliverableReview @default(PENDING)
  reviewerId    String?
  feedback      String?
}

model SkillAssessment {
  id            String  @id @default(cuid())
  userId        String
  skill         String
  startingLevel String
  currentLevel  String
  evidence      String?
  assessedById  String?
  createdAt     DateTime @default(now())

  @@index([userId])
}

// ─────────────────── Reviews L1–L4 + 360° (M5) ───────────────────
model MenteeUpdate {
  id       String   @id @default(cuid()) // L1, append-only
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  teamId   String?
  squadId  String?
  date     DateTime @default(now())
  workedOn String
  learning String
  blocker  String?
  nextGoal String

  @@index([userId, date])
}

model MentorStatus {
  id              String         @id @default(cuid()) // L2
  menteeId        String
  mentorId        String
  date            DateTime       @default(now())
  updatesThisWeek Int            @default(0)
  lastUpdateAt    DateTime?
  blockerStreak   Int            @default(0)
  statusL2        MenteeStatusL2 @default(DOING_WELL)
  daysSinceUpdate Int            @default(0)
  comment         String?
  actionNeeded    String?

  @@index([menteeId, date])
}

model WeeklyReview {
  id              String             @id @default(cuid()) // L3 (mentor) + L4 (teacher)
  weekNo          Int
  menteeId        String
  mentorId        String
  domainId        String?
  squadId         String?
  progressSummary String?
  strength        String?
  improvementArea String?
  autoFlag        AutoFlag           @default(NONE)
  mentorStatus    MentorStatusL3?
  teacherDecision TeacherDecisionL4?
  teacherNotes    String?
  teacherId       String?
  l4CompletedAt   DateTime?
  createdAt       DateTime           @default(now())

  @@unique([weekNo, menteeId])
  @@index([menteeId])
}

model MentorFeedback {
  id              String   @id @default(cuid()) // 360°
  menteeId        String
  mentorId        String
  date            DateTime @default(now())
  mentorAvailable Boolean
  feedbackUseful  Boolean
  comments        String?
}

model MentorshipLog {
  id               String   @id @default(cuid()) // Section G
  mentorId         String
  menteeId         String
  date             DateTime @default(now())
  discussionSummary String
  actionItems      String?
  nextCheckinAt    DateTime?
}

model Attendance {
  id      String @id @default(cuid())
  eventId String
  userId  String
  status  String // Present | Absent | Excused
}

model Evaluation {
  id          String  @id @default(cuid())
  rubricId    String
  subjectType String // Team | User
  subjectId   String
  scores      Json
  total       Float
  rank        Int?
  evaluatorId String?
  createdAt   DateTime @default(now())
}

// ─────────────────── Concerns & Demerits (M6) ───────────────────
model Concern {
  id            String          @id @default(cuid())
  seq           Int             @default(autoincrement()) // human ticket number → "CON-<seq>"
  raisedById    String
  raisedBy      User            @relation("ConcernRaisedBy", fields: [raisedById], references: [id])
  category      ConcernCategory
  subjectUserId String?
  teamId        String?
  domainId      String?
  milestoneId   String?
  title         String
  description   String
  severity      Severity        @default(MEDIUM)
  anonymous     Boolean         @default(false)
  status        ConcernStatus   @default(OPEN)
  assignedToId  String?
  assignedTo    User?           @relation("ConcernAssignee", fields: [assignedToId], references: [id])
  slaDueAt      DateTime?
  resolutionNote String?
  resolvedAt    DateTime?
  events        ConcernEvent[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status])
  @@index([raisedById])
}

model ConcernEvent {
  id         String        @id @default(cuid())
  concernId  String
  concern    Concern       @relation(fields: [concernId], references: [id], onDelete: Cascade)
  actorId    String?
  fromStatus ConcernStatus?
  toStatus   ConcernStatus
  note       String?
  at         DateTime      @default(now())

  @@index([concernId])
}

model Demerit {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation("DemeritUser", fields: [userId], references: [id])
  reason     String
  points     Int     @default(1)
  issuedById String?
  policyRef  String?
  escalated  Boolean @default(false)
  createdAt  DateTime @default(now())
}

// ─────────────────── Communications (M7) ───────────────────
model EmailTemplate {
  id        String  @id @default(cuid())
  name      String
  subject   String
  body      String
  variables Json?
  ownerRole RoleKey?
  emails    Email[]
  updatedAt DateTime @updatedAt
}

model Email {
  id          String      @id @default(cuid())
  senderId    String?
  subject     String
  body        String
  recipients  Json
  cc          Json?
  attachments Json?
  status      EmailStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  templateId  String?
  template    EmailTemplate? @relation(fields: [templateId], references: [id])
  createdAt   DateTime    @default(now())
}

model Announcement {
  id        String   @id @default(cuid())
  authorId  String
  scopeType String
  scopeId   String?
  title     String
  body      String
  channels  Json // ["inapp","email","discord"]
  createdAt DateTime @default(now())
}

model Notification {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String
  payload      Json
  readAt       DateTime?
  sentChannels Json?
  createdAt    DateTime @default(now())

  @@index([userId, readAt])
}

model NotificationRule {
  id         String  @id @default(cuid())
  triggerKey String
  audience   Json
  cc         Json?
  channels   Json
  templateId String?
  active     Boolean @default(true)
}

// ─────────────────── Integrations (M8) ───────────────────
model IntegrationAccount {
  id            String              @id @default(cuid())
  provider      IntegrationProvider
  scopeType     String
  scopeId       String?
  externalId    String?
  credentialsRef String? // encrypted reference, never raw token
  status        String              @default("connected")
  lastSyncedAt  DateTime?
}

model GithubActivity {
  id         String       @id @default(cuid())
  teamId     String?
  userId     String?
  repo       String? // source repo full name, e.g. "newton-school-ai/engageiq-ai"
  type       ActivityType
  externalId String       @unique
  title      String?
  state      String?
  url        String?
  occurredAt DateTime
  raw        Json?

  @@index([teamId, occurredAt])
  @@index([repo, occurredAt])
}

model DiscordActivity {
  id         String       @id @default(cuid())
  teamId     String?
  userId     String?
  channelId  String?
  type       ActivityType
  occurredAt DateTime
  raw        Json?

  @@index([teamId, occurredAt])
}

model CalendarEvent {
  id              String            @id @default(cuid())
  scopeType       String
  scopeId         String?
  title           String
  type            CalendarEventType
  startsAt        DateTime
  endsAt          DateTime?
  externalEventId String?
  attendees       Json?
}

// ─────────────────── Audit (M11) ───────────────────
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  at         DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId, at])
}

// ─────────── Testing Portal (Phase-2 backend for the tester experience) ───────────
// Server-persisted tester progress + issue reports. Testers are an email allowlist
// (see testing module); these tables don't FK to User so external/admin testers work too.
enum TestSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TestDomainStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

/** A tester's progress through one domain's guided test plan (Resume across devices). */
model TestingProgress {
  id          String           @id @default(cuid())
  testerEmail String
  domainKey   String // AI | ML | DVA | SDSE
  status      TestDomainStatus @default(NOT_STARTED)
  done        String[] // completed step ids
  skipped     String[] // skipped step ids
  current     Int              @default(0)
  updatedAt   DateTime         @updatedAt

  @@unique([testerEmail, domainKey])
}

/** A domain's guided test plan — DB-backed so the script is editable without a redeploy. */
model TestPlan {
  id        String         @id @default(cuid())
  domainKey String         @unique // AI | ML | DVA | SDSE
  name      String // domain display name
  model     String // one-line description of the domain's GitHub model
  steps     TestPlanStep[]
  updatedAt DateTime       @updatedAt
}

/** One guided step within a test plan (ordered; stepKey is the stable progress id). */
model TestPlanStep {
  id          String   @id @default(cuid())
  planId      String
  plan        TestPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  seq         Int // render order
  stepKey     String // stable id used in TestingProgress.done/skipped (e.g. "AI-um-invite")
  group       String // checklist category
  role        String // act-as role label
  title       String
  instruction String
  expected    String
  success     String

  @@unique([planId, stepKey])
  @@index([planId, seq])
}

/** An issue a tester reported on a step (emailed to the Testing Admin). */
model TestIssue {
  id          String       @id @default(cuid())
  testerEmail String
  domainKey   String
  stepId      String?
  title       String
  description String?
  severity    TestSeverity @default(MEDIUM)
  createdAt   DateTime     @default(now())

  @@index([testerEmail])
  @@index([domainKey])
}
