# Forge server — local env (git-ignored). In prod these come from AWS Secrets
# Manager (/forge/<env>/*), injected into the ECS task — never committed.
# See docs/integration-setup.md.

NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:3000

# Database (RDS Postgres in prod; local postgres via docker-compose)
DATABASE_URL=postgresql://forge:forge@localhost:5432/forge?schema=public
DIRECT_URL=postgresql://forge:forge@localhost:5432/forge?schema=public

# Sessions (Redis-backed)
REDIS_URL=redis://localhost:6379
SESSION_SECRET=

# Google OAuth (login) — the ONLY auth method
ALLOWED_HOSTED_DOMAIN=rishihood.edu.in
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# GitHub (App + webhooks)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_GUILD_ID=

# Google Calendar
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=primary

# Email (SMTP) — nodemailer. Gmail/Workspace: host smtp.gmail.com, port 587,
# SMTP_PASS = a 16-char App Password (needs 2FA). AWS SES: email-smtp.<region>.amazonaws.com.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
