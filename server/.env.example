# Forge server — local env (git-ignored). In prod these come from the host's env
# settings (Render service env / AWS Secrets Manager) — never committed.
# See docs/integration-setup.md.
#
# Live production (set on the Render backend service):
#   APP_BASE_URL=https://forge.taj.works                 (frontend origin)
#   GOOGLE_OAUTH_REDIRECT_URI=https://forge.server.taj.works/api/auth/google/callback
#   GITHUB_OAUTH_REDIRECT_URI=https://forge.server.taj.works/api/integrations/github/oauth/callback
#   REDIS_URL=rediss://… (Upstash, secret)
# Frontend (Vercel): NEXT_PUBLIC_API_URL=https://forge.server.taj.works/api

NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:3000   # prod: https://forge.taj.works

# Database (RDS Postgres in prod; local postgres via docker-compose)
DATABASE_URL=postgresql://forge:forge@localhost:5432/forge?schema=public
DIRECT_URL=postgresql://forge:forge@localhost:5432/forge?schema=public

# Sessions (Redis-backed). Prod: a managed TLS Redis, e.g. Upstash (rediss://…) — set
# it in the host env, never commit the URL (it contains the password).
REDIS_URL=redis://localhost:6379
SESSION_SECRET=
# Hard session lifetime cap (hours) regardless of activity; idle window is the cookie maxAge.
SESSION_ABSOLUTE_HOURS=24

# Google OAuth (login) — the ONLY auth method
ALLOWED_HOSTED_DOMAIN=rishihood.edu.in
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# GitHub — six values cover ALL domains. See docs/github-setup.html.
#   AI runs on a GitHub org (org webhook + read token + Teams).
#   ML/SDSE have no org: each team adds a PER-REPO webhook reusing the SAME secret —
#     created automatically when a mentor clicks "Connect with GitHub" + submits the repo URL.
#   Per-user GitHub usernames are linked in-app (Connections tab), NOT here.
# No GitHub App, no per-user tokens stored.
GITHUB_ORG=newton-school-ai     # AI org slug (the only GitHub-driven domain)
GITHUB_API_TOKEN=               # fine-grained PAT, Read-only on the AI org (+ public ML/SDSE repos)
GITHUB_WEBHOOK_SECRET=          # HMAC secret — AI org webhook AND every ML/SDSE repo webhook

# One-click "Connect with GitHub" — OAuth App owned by the lcc-ai-nst account.
# Verifies each user's username and lets a mentor's one click auto-create the repo webhook.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/github/oauth/callback

# Repository mode (ML/DVA/SDSE public repos). The machine account is added as a read
# collaborator on connect; its optional classic PAT (public_repo scope) raises the read
# rate limit + enables collaborator listing. Reads also work unauthenticated (public).
GITHUB_READER_LOGIN=lcc-ai-nst
GITHUB_READER_TOKEN=

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_GUILD_ID=

# Google Calendar
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=primary

# Email (SMTP) — nodemailer. Gmail/Workspace: host smtp.gmail.com, port 587,
# SMTP_PASS = a 16-char App Password (needs 2FA). AWS SES: email-smtp.<region>.amazonaws.com.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Internal jobs secret — gates POST /api/public/stats/recompute (landing metrics).
# A scheduled cron sends header `x-jobs-secret: <this>`. Unset => recompute disabled.
# Generate: openssl rand -hex 32
JOBS_SECRET=

# Concern notifications — CC the organizing team (comma-separated). "to" is always the LCC.
CONCERN_CC_EMAILS=
